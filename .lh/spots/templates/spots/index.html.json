            "name": "Commit-0",
            "content": "{% extends \"base.html\" %}\n{% load static %}\n\n{% block content %}\n<div class=\"container py-4\">\n    <h1 class=\"mb-4\">Best Foods in Konkan</h1>\n\n    <div class=\"row g-4\">\n        {% for item in  %}\n        <div class=\"col-12 col-md-6 col-lg-4\">\n            <div class=\"card shadow-sm h-100\">\n                {% if item.photo %}\n                    <img src=\"{{ item.photo.url }}\" class=\"card-img-top\" alt=\"{{ item.name }}\" style=\"height:200px; object-fit:cover;\">\n                {% endif %}\n\n                <div class=\"card-body\">\n                    <h3 class=\"card-title\">{{ item.name }}</h3>\n                    <p class=\"card-text text-muted\">\n                        {{ item.description}}\n                    </p>\n                      <p class=\"card-text text-muted\">\n                        {{ item.rating}} ⭐\n                    </p>\n                    <p class=\"card-text text-muted\">\n                    Price - {{ item.price}}\n                   </p>\n\n                    <a href=\"{% url 'details' item.id %}\" class=\"btn btn-primary btn-sm\">\n                        View Details\n                    </a>\n                      <a href=\"{% url 'update_food' item.id %}\" class=\"btn btn-secondary btn-sm\">\n                        Edit\n                    </a>\n                    <a href=\"{% url 'delete_food' item.id %}\" class=\"btn btn-danger btn-sm\">\n                        Delete\n                    </a>\n                     <a href=\"{{ item.recipe_link }}\" class=\"btn btn-info btn-sm\" target=\"_blank\">\n                        Recipe\n                    </a>\n                </div>\n            </div>\n        </div>\n        {% endfor %}\n    </div>\n\n</div>\n{% endblock content %}\n"
