            "date": 1763222788321,
            "name": "Commit-0",
            "content": "{% extends \"base.html\" %}\n<html>\n    <head>\n        <meta charset=\"utf-8\">\n        <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n        <title>second page</title>\n        <meta name=\"description\" content=\"\">\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n        <link rel=\"stylesheet\" href=\"\">\n    </head>\n    <body>\n       <h1>Where to travel</h1>\n         <p> This is the about page of the konkan guide website. Here you will find information about various travel spots in the Konkan region.</p>\n\n{% block content %}\n<div class=\"container py-5\">\n\n    <!-- Hero Section -->\n    <div class=\"row g-4 mb-4\">\n        <div class=\"col-12 col-lg-6\">\n            <div class=\"rounded shadow-sm overflow-hidden\">\n                {% if spots.photo %}\n                    <img src=\"{{ spots.photo.url }}\" class=\"img-fluid w-100\" style=\"height:350px; object-fit:cover;\">\n                {% else %}\n                    <img src=\"https://via.placeholder.com/600x350\" class=\"img-fluid w-100\">\n                {% endif %}\n            </div>\n        </div>\n\n        <div class=\"col-12 col-lg-6 d-flex flex-column justify-content-center\">\n            <h1 class=\"fw-bold\">{{ spots.name }}</h1>\n\n            <p class=\"text-muted mb-1\">Category: {{ spots.category }}</p>\n            <p class=\"text-muted mb-1\">Price: {{ spots.price }} /-</p>\n            <p class=\"text-muted mb-2\">Rating: ⭐ {{ spots.rating }}/5</p>\n            <div class=\"mt-3\">\n                <a href=\"{{ spot3.map_location }}\" \n                   class=\"btn btn-warning text-dark fw-semibold px-4\" \n                   target=\"_blank\">\n                    📍 View on Map\n                </a>\n            </div>\n        </div>\n    </div>\n\n    <!-- Details Section -->\n    <div class=\"row g-4\">\n        <div class=\"col-12 col-lg-8\">\n            <div class=\"card shadow-sm border-0\">\n                <div class=\"card-body\">\n                    <h4 class=\"fw-bold mb-3\">Description</h4>\n                    <p class=\"text-muted\">{{ food_items.description }}</p>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"col-12 col-lg-4\">\n            <div class=\"card shadow-sm border-0 mb-4\">\n                <div class=\"card-body\">\n                    <h5 class=\"fw-bold mb-3\">Timings</h5>\n\n                    <p class=\"mb-1\">\n                        <span class=\"badge bg-success px-3 py-2\">Opens: {{  food_items.opening_hours }}</span>\n                    </p>\n                    <p>\n                        <span class=\"badge bg-danger px-3 py-2\">Closes: {{ food_items.closing_hours }}</span>\n                    </p>\n                </div>\n            </div>\n        </div>\n    </div>\n\n</div>\n{% endblock %}\n\n        <script src=\"\" async defer></script>\n    </body>\n</html>\n\n\n"
        }
