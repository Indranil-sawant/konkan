            "date": 1763478149000,
            "name": "Commit-0",
            "content": "{% extends \"base.html\" %}\n{% load static %}\n\n{% block content %}\n\n<div class=\"container mt-5\">\n\n    <!-- Profile Card -->\n    <div class=\"card shadow-sm p-4\" style=\"max-width: 700px; margin: auto; border-radius: 15px;\">\n\n        <!-- Header background -->\n        <div class=\"profile-header\" \n             style=\"height: 120px; \n                    background: linear-gradient(90deg, #007bff, #6f42c1); \n                    border-radius: 12px;\">\n        </div>\n\n        <!-- Profile image -->\n        <div class=\"text-center\" style=\"margin-top: -60px;\">\n            <img src=\"{{ profile.profile_image.url }}\" \n                 class=\"rounded-circle shadow\"\n                 style=\"width: 120px; height: 120px; object-fit: cover; border: 4px solid white;\"\n                 alt=\"{{ profile.name }}\">\n        </div>\n\n        <!-- Name + intro -->\n        <div class=\"text-center mt-3\">\n            <h2 class=\"fw-bold\">{{ profile.name }}</h2>\n            <p class=\"text-muted\">{{ profile.short_intro }}</p>\n        </div>\n\n        <hr>\n\n        <!-- Bio -->\n        <div class=\"mt-3\">\n            <h5 class=\"fw-bold mb-2\">About</h5>\n            <p class=\"text-secondary\" style=\"line-height: 1.6;\">\n                {{ profile.bio|linebreaks }}\n            </p>\n        </div>\n\n        <hr>\n\n        <!-- Profile details -->\n        <div class=\"mt-3\">\n            <h5 class=\"fw-bold mb-2\">Details</h5>\n            <p><strong>Email:</strong> {{ profile.email }}</p>\n            <p><strong>Username:</strong> {{ profile.username }}</p>\n        </div>\n\n        <hr>\n\n        <!-- Social Links -->\n        <div class=\"mt-3\">\n            <h5 class=\"fw-bold mb-3\">Social Links</h5>\n\n            <div class=\"d-flex gap-3\">\n\n                {% if profile.social_github %}\n                <a href=\"{{ profile.social_github }}\" class=\"fs-4\" target=\"_blank\">\n                    <i class=\"fa-brands fa-github\"></i>\n                </a>\n                {% endif %}\n\n                {% if profile.social_linkedin %}\n                <a href=\"{{ profile.social_linkedin }}\" class=\"fs-4 text-primary\" target=\"_blank\">\n                    <i class=\"fa-brands fa-linkedin\"></i>\n                </a>\n                {% endif %}\n\n                {% if profile.social_twitter %}\n                <a href=\"{{ profile.social_twitter }}\" class=\"fs-4 text-info\" target=\"_blank\">\n                    <i class=\"fa-brands fa-twitter\"></i>\n                </a>\n                {% endif %}\n\n                {% if profile.social_youtube %}\n                <a href=\"{{ profile.social_youtube }}\" class=\"fs-4 text-danger\" target=\"_blank\">\n                    <i class=\"fa-brands fa-youtube\"></i>\n                </a>\n                {% endif %}\n\n                {% if profile.social_website %}\n                <a href=\"{{ profile.social_website }}\" class=\"fs-4 text-success\" target=\"_blank\">\n                    <i class=\"fa-solid fa-globe\"></i>\n                </a>\n                {% endif %}\n\n            </div>\n        </div>\n\n    </div>\n\n</div>\n\n{% endblock %}\n"
        }
    ]
}